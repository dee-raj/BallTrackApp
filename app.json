{
  "expo": {
    "name": "BallTrack",
    "slug": "BallTrack",
    "version": "1.0.1",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.balltrack.app",
      "versionCode": 2
    },
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.balltrack.app",
      "buildNumber": "2"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you select player photos and team logos.",
          "cameraPermission": "The app accesses your camera to let you take player photos and team logos."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "owner": "deeraj"
  }
}